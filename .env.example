# =============================================================
# DATA AGENTS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit do arquivo .env
# =============================================================

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Databricks ---
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXX.XX.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_SQL_WAREHOUSE_ID=XXXXXXXXXXXXXXXX

# --- Microsoft Fabric / Azure ---
AZURE_TENANT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
AZURE_CLIENT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
AZURE_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FABRIC_WORKSPACE_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com/v1

# --- Fabric RTI (Eventhouse / Kusto) ---
KUSTO_SERVICE_URI=https://XXXXXXXXXXXXXXXXXXXXXXXX.z1.kusto.fabric.microsoft.com
KUSTO_SERVICE_DEFAULT_DB=meu_database

# --- Fabric Community MCP ---
# Comando do servidor MCP da comunidade (instalado via pip install -e ".[dev]")
# Padrão funciona se o ambiente conda/venv estiver ativado.
# Se necessário, use o caminho absoluto do binário no seu ambiente:
# FABRIC_COMMUNITY_COMMAND=/opt/anaconda3/envs/multi_agents/bin/microsoft-fabric-mcp
FABRIC_COMMUNITY_COMMAND=microsoft-fabric-mcp

# --- Fabric MCP Server Oficial (opcional, não ativo por padrão) ---
# Servidor local-first da Microsoft: fornece OpenAPI specs e schemas, sem conexão ao tenant.
# Ref: https://github.com/microsoft/mcp/tree/main/servers/Fabric.Mcp.Server
# Não requer credenciais. Para ativar no futuro, consulte o README.
# FABRIC_MCP_SERVER_PATH=./mcp_servers/fabric/Fabric.Mcp.Server

# --- Configurações do Sistema ---
DEFAULT_MODEL=claude-opus-4-6
MAX_BUDGET_USD=5.0
MAX_TURNS=50
LOG_LEVEL=INFO
AUDIT_LOG_PATH=./logs/audit.jsonl
